# Tessera On-Chain Migration Environment Variables
# Copy this file to .env.migration and fill in your values
# DO NOT commit .env.migration to git!

# ============================================================
# Solana Network Configuration
# ============================================================

# Target network for migration (localnet, devnet, testnet, mainnet-beta)
SOLANA_NETWORK=devnet

# RPC endpoint URLs
SOLANA_RPC_URL_LOCALNET=http://127.0.0.1:8899
SOLANA_RPC_URL_DEVNET=https://api.devnet.solana.com
SOLANA_RPC_URL_TESTNET=https://api.testnet.solana.com
SOLANA_RPC_URL_MAINNET=https://api.mainnet-beta.solana.com

# WebSocket endpoint URLs (optional)
SOLANA_WS_URL_DEVNET=wss://api.devnet.solana.com
SOLANA_WS_URL_TESTNET=wss://api.testnet.solana.com
SOLANA_WS_URL_MAINNET=wss://api.mainnet-beta.solana.com

# ============================================================
# Program IDs
# ============================================================

# Tessera Token Program ID
TESSERA_TOKEN_PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS

# Referral System Program ID
REFERRAL_SYSTEM_PROGRAM_ID=RefSys1111111111111111111111111111111111111

# ============================================================
# Authority Keypair
# ============================================================

# Path to authority keypair JSON file
# This wallet will pay for migration transactions and rent
# IMPORTANT: Ensure this wallet has sufficient SOL!
MIGRATION_AUTHORITY_KEYPAIR=~/.config/solana/id.json

# Alternative: Base58 encoded private key (not recommended for production)
# MIGRATION_AUTHORITY_PRIVATE_KEY=

# ============================================================
# Cloudflare Configuration (for production data export)
# ============================================================

# Cloudflare Account ID
CF_ACCOUNT_ID=

# Cloudflare D1 Database ID
CF_DATABASE_ID=

# Cloudflare API Token with D1 read permissions
CF_API_TOKEN=

# ============================================================
# Migration Configuration
# ============================================================

# Batch size for migration (number of codes to process at once)
MIGRATION_BATCH_SIZE=10

# Delay between batches in milliseconds
MIGRATION_BATCH_DELAY_MS=2000

# Maximum retries for failed transactions
MIGRATION_MAX_RETRIES=3

# Enable dry-run mode (simulate without actually executing)
MIGRATION_DRY_RUN=false

# ============================================================
# Referral System Parameters
# ============================================================

# Default fee reduction percentage (basis points, e.g., 2000 = 20%)
DEFAULT_FEE_REDUCTION_PERCENTAGE=2000

# Tier 1 (direct referrer) split percentage (basis points, e.g., 3000 = 30%)
TIER1_SPLIT_PERCENTAGE=3000

# Tier 2 (grandparent) split percentage (basis points, e.g., 300 = 3%)
TIER2_SPLIT_PERCENTAGE=300

# Tier 3 (great-grandparent) split percentage (basis points, e.g., 200 = 2%)
TIER3_SPLIT_PERCENTAGE=200

# ============================================================
# Cost Estimates
# ============================================================

# Estimated SOL price in USD (for cost calculations)
SOL_PRICE_USD=200

# Rent exemption costs (in SOL)
RENT_PER_REFERRAL_CODE=0.001
RENT_PER_USER_REGISTRATION=0.002

# Transaction fee (in SOL)
TRANSACTION_FEE=0.000005

# ============================================================
# Safety & Monitoring
# ============================================================

# Enable verbose logging
VERBOSE_LOGGING=true

# Save transaction logs to file
SAVE_TRANSACTION_LOGS=true

# Transaction log directory
TRANSACTION_LOG_DIR=./data/logs

# Enable Slack notifications (optional)
SLACK_WEBHOOK_URL=

# Enable Discord notifications (optional)
DISCORD_WEBHOOK_URL=

# ============================================================
# Frontend Configuration
# ============================================================

# Solana Network - determines which network the frontend connects to
# Options: 'devnet' | 'mainnet-beta'
# This is the primary configuration that controls network selection
VITE_SOLANA_NETWORK=devnet

# Solana RPC URL for frontend (used in Vite)
# Optional - will use defaults from config.ts if not set
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# Referral program ID for frontend
VITE_REFERRAL_PROGRAM_ID=RefSys1111111111111111111111111111111111111

# Enable devnet mode in UI
VITE_ENABLE_DEVNET=true

# ============================================================
# Testing & Development
# ============================================================

# Enable test mode (uses mock data)
TEST_MODE=false

# Use local validator
USE_LOCAL_VALIDATOR=false

# Local validator RPC URL
LOCAL_VALIDATOR_URL=http://127.0.0.1:8899

# ============================================================
# Rollback Configuration
# ============================================================

# D1 database backup path (for rollback)
D1_BACKUP_PATH=./data/backups/d1-backup.sql

# Enable automatic rollback on failure
AUTO_ROLLBACK_ON_FAILURE=false

# ============================================================
# Notes
# ============================================================

# For production migration:
# 1. Set SOLANA_NETWORK=mainnet-beta
# 2. Use mainnet RPC URL
# 3. Ensure authority wallet has sufficient SOL
# 4. Test thoroughly on devnet first!
# 5. Create database backup before migration
# 6. Set up monitoring and alerts
# 7. Have rollback plan ready

# Estimated costs (example for 100 codes, 1000 users):
# - Referral codes: 100 × 0.001 SOL = 0.1 SOL
# - User registrations: 1000 × 0.002 SOL = 2 SOL
# - Transaction fees: 1100 × 0.000005 SOL = 0.0055 SOL
# - Total: ~2.1 SOL (~$420 at $200/SOL)
