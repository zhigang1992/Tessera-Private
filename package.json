{
  "name": "Tessera",
  "scripts": {
    "build": "tsc && vite build",
    "ci": "bun run build && bun run lint && bun run format:check",
    "dev": "vite",
    "cf:dev": "wrangler pages dev dist --compatibility-date=2025-03-01",
    "cf:pages:build": "bun run build",
    "cf:deploy": "wrangler pages deploy dist",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "migrate:export": "bun run scripts/export-production-data.ts",
    "migrate:devnet": "bun run scripts/migrate-to-devnet.ts",
    "test:wallets": "bun run scripts/generate-test-wallets.ts",
    "mobile:icons": "pwa-assets-generator",
    "mobile:bubblewrap:init:dev": "mkdir -p android/dev && cd android/dev && bubblewrap init --manifest=\"https://${TESSERA_APK_HOST:-dev.tessera.fun}/manifest.webmanifest\"",
    "mobile:bubblewrap:update:dev": "cd android/dev && BUBBLEWRAP_KEYSTORE_PASSWORD=tessera-dev BUBBLEWRAP_KEY_PASSWORD=tessera-dev bubblewrap update",
    "mobile:bubblewrap:build:dev": "cd android/dev && BUBBLEWRAP_KEYSTORE_PASSWORD=tessera-dev BUBBLEWRAP_KEY_PASSWORD=tessera-dev bubblewrap build",
    "mobile:bubblewrap:init:prod": "mkdir -p android/prod && cd android/prod && bubblewrap init --manifest=\"https://${TESSERA_APK_HOST:-app.tessera.pe}/manifest.webmanifest\"",
    "mobile:bubblewrap:update:prod": "cd android/prod && bubblewrap update",
    "mobile:bubblewrap:build:prod": "cd android/prod && bubblewrap build",
    "mobile:dappstore:init": "cd dapp-store && dapp-store init",
    "mobile:dappstore:validate": "cd dapp-store && dapp-store validate -b ../android/prod/app-release-signed.apk",
    "mobile:dappstore:publish": "cd dapp-store && dapp-store publish submit --requestor-is-authorized"
  },
  "description": "React+Vite, Tailwind, gill (based on @solana/kit), Wallet UI",
  "keywords": [
    "gill",
    "react",
    "solana-kit",
    "tailwind",
    "typescript",
    "vite",
    "wallet-ui"
  ],
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@dynamic-labs/sdk-react-core": "^4.48.1",
    "@dynamic-labs/solana": "^4.48.1",
    "@jup-ag/api": "^6.0.48",
    "@meteora-ag/alpha-vault": "^1.1.15",
    "@meteora-ag/dlmm": "^1.9.0",
    "@meteora-ag/presale": "^0.1.0",
    "@noble/curves": "^1.4.2",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@solana-mobile/wallet-standard-mobile": "^0.4.1",
    "@solana/spl-token": "^0.3.8",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@solana/web3.js": "^1.98.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.13",
    "@tanstack/react-query": "^5.89.0",
    "bn.js": "^5.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decimal.js": "^10.6.0",
    "framer-motion": "^12.23.24",
    "gill": "0.11.0",
    "jose": "^6.2.2",
    "jotai": "^2.14.0",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.544.0",
    "math-literal": "^0.1.3",
    "next-themes": "^0.4.6",
    "qrcode-svg": "^1.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-error-boundary": "^6.0.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.9.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.3.8",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@bubblewrap/cli": "1.24.1",
    "@cloudflare/workers-types": "^4.20250927.0",
    "@eslint/js": "^9.35.0",
    "@solana-mobile/dapp-store-cli": "0.16.0",
    "@types/bn.js": "^5.2.0",
    "@types/bs58": "^5.0.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vite-pwa/assets-generator": "1.0.2",
    "@vitejs/plugin-react": "^5.0.3",
    "bs58": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "puppeteer": "^24.22.3",
    "react-grab": "^0.0.98",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.6",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vite-plugin-pwa": "1.2.0",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.40.2"
  },
  "packageManager": "bun@1.2.22"
}
